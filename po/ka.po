#: src/dfc.c:448
msgid ""
"Usage:  dfc [OPTION(S)] [-c WHEN] [-e FORMAT] [-p FSNAME] [-q SORTBY] [-t "
"FSTYPE] [-u UNIT]\n"
"Available options:\n"
"\t-a\tprint all mounted filesystem\n"
"\t-b\tdo not show the graph bar\n"
"\t-c\tchoose color mode. Read the manpage for details\n"
"\t-d\tshow used size\n"
"\t-e\texport to specified format. Read the manpage for details\n"
"\t-f\tdisable auto-adjust mode (force display)\n"
"\t-h\tprint this message\n"
"\t-i\tinfo about inodes\n"
"\t-l\tonly show information about locally mounted file systems\n"
msgstr ""
"გამოყენება:  dfc [პარამეტრ(ებ)-ი] [-c როდის] [-e ფორმატი] [-p ფსსახელი] [-q "
"დალაგ.პირ.] [-t ფსტიპი] [-u ერთეული]\n"
"ხელმისაწვდომი პარამეტრები:\n"
"\t-a\tყველა მიმაგრებული ფაილური სისტემის გამოტანა\n"
"\t-b\tგრაფიკის ზოლი ნაჩვენები არ იქნება\n"
"\t-c\tფერის რეჟიმის არჩევა. დეტალებისთვის წაიკითხეთ სახელმძღვანელო\n"
"\t-d\tგამოყენებული ზომის ჩვენება\n"
"\t-e\tგატანა მითითებულ ფორმატში. დეტალებისთვის წაიკითხეთ სახელმძღვანელო\n"
"\t-f\tავტოგასწორების რეჟიმის გამორთვა (ნაძალადევი ჩვენება \n"
"\t-h\tამ შეტყობინების გამოტანა\n"
"\t-i\tინფორმაცია inode-ების შესახებ\n"
"\t-l\tინფორმაციის გამოტანა, მხოლოდ, ლოკალურად მიმაგრებული ფაილური "
"სისტემების შესახებ\n"

#: src/dfc.c:466
msgid ""
"\t-m\tuse metric (SI unit)\n"
"\t-M\tdo not print \"mounted on\"\n"
"\t-n\tdo not print header\n"
"\t-o\tshow mount flags\n"
"\t-p\tfilter by file system name. Read the manpage for details\n"
"\t-q\tsort the output. Read the manpage for details\n"
"\t-s\tsum the total usage\n"
"\t-t\tfilter by file system type. Read the manpage for details\n"
"\t-T\tshow filesystem type\n"
"\t-u\tchoose the unit in which to show the values. Read the manpage for "
"details\n"
"\t-v\tprint program version\n"
"\t-w\tuse a wider bar\n"
"\t-W\twide filename (un truncate)\n"
msgstr ""
"\t-m\tმეტრული (SI სისტემის) სისტემის გამოყენება\n"
"\t-M\t\"მიმაგრების წერტილი\" გამოტანილი არ იქნება\n"
"\t-n\tთავსართი გამოტანილი არ იქნება\n"
"\t-o\tმიმაგრების ალმების ჩვენება\n"
"\t-p\tგაფილტვრა ფაილური სისტემის სახელით. დეტალებისთვის წაიკითხეთ "
"სახელმძღვანელო\n"
"\t-q\tგამოტანის დალაგება. დეტალებისთვის წაიკითხეთ სახელმძღვანელო\n"
"\t-s\tსრული გამოყენების შეჯამება\n"
"\t-t\tგაფილტვრა ფაილური სისტემის ტიპით. დეტალებისთვის წაიკითხეთ "
"სახელმძღვანელო\n"
"\t-T\tფაილური სისტემის ტიპის ჩვენება\n"
"\t-u\tაირჩიეთ ერთეული, რომლითაც მნიშვნელობების ჩვენება მოხდება. "
"დეტალებისთვის წაიკითხეთ სახელმძღვანელო\n"
"\t-v\tპროგრამის ვერსიის გამოტანა\n"
"\t-w\tუფრო განიერი პანელის ჩვენება\n"
"\t-W\tგანიერი ფაილის სახელი (წაკვეთის გაუქმება\n"

